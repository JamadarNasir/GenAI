# ─── Backend Server ─────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend (Vite) ────────────────────────────────
VITE_API_URL=http://localhost:4000

# ─── AI Provider ────────────────────────────────────
AI_PROVIDER=openai          # openai | azure | local

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Local LLM (Ollama)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# ─── Playwright MCP ─────────────────────────────────
# Set MCP_PLAYWRIGHT_ENABLED=true to activate the /api/mcp/* endpoints.
# USE_REAL_MCP=false  → mock client (no browser spawned, safe for dev/CI)
# USE_REAL_MCP=true   → real client (spawns `npx @playwright/mcp@latest`)
MCP_PLAYWRIGHT_ENABLED=false
USE_REAL_MCP=false

# ─── Test Execution ─────────────────────────────────
BASE_URL=https://your-app-under-test.com
DEFAULT_BROWSER=chromium
HEADLESS=true
PARALLEL_WORKERS=4
